# Copy to .env and fill in real values. Never commit .env.

# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flowershop?schema=public"

# Secret used to sign admin session tokens. Generate with:
#   openssl rand -base64 48
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Public base URL of the deployed site (used for SEO metadata & sitemap).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Seed credentials for the first admin user (used by prisma/seed.ts only).
SEED_ADMIN_EMAIL="admin@flowershop.local"
SEED_ADMIN_PASSWORD="admin12345"
